{
  "name": "yeri-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NEXT_PUBLIC_GIT_SHA=$(git rev-parse --short HEAD) next dev -H 0.0.0.0",
    "build": "NEXT_PUBLIC_GIT_SHA=$(git rev-parse --short HEAD) next build",
    "start": "next start -H 0.0.0.0",
    "lint": "eslint",
    "check:tokens": "bash scripts/check-tokens.sh",
    "prebuild": "bash scripts/check-tokens.sh"
  },
  "dependencies": {
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "pretendard": "^1.3.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "styled-components": "^6.4.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "typescript": "^5"
  }
}