{
  "name": "feedback-widget",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.tsx --bundle --minify --format=iife --outfile=dist/widget.js --jsx=automatic --loader:.css=text",
    "dev": "esbuild src/index.tsx --bundle --format=iife --outfile=dist/widget.js --jsx=automatic --loader:.css=text --watch=forever --servedir=dist --serve=0.0.0.0:4000",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node test/smoke.mjs"
  },
  "dependencies": {
    "@ingradient/ui": "file:../vendor/ingradient-ui-0.0.1.tgz",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "styled-components": "^6.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "esbuild": "^0.25.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.8.0"
  }
}
