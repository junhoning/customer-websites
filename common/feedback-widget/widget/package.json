{
  "name": "feedback-widget",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --minify --format=iife --outfile=dist/widget.js",
    "dev": "esbuild src/index.ts --bundle --format=iife --outfile=dist/widget.js --watch=forever --servedir=dist --serve=0.0.0.0:4000",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node test/smoke.mjs"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.8.0"
  }
}
